generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Member {
  id             Int             @id @default(autoincrement())
  name           String
  email          String          @default("")
  role           String          @default("Employee")
  createdAt      DateTime        @default(now()) @map("created_at")
  discipline     String          @default("")
  skills         Json            @default("[]")
  leftDate       String          @default("") @map("left_date")
  status         String          @default("active")
  projectMembers ProjectMember[]
  user           User?

  @@map("members")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("Member")
  mustReset    Boolean  @default(true) @map("must_reset")
  createdAt    DateTime @default(now()) @map("created_at")
  memberId     Int?     @unique @map("member_id")
  member       Member?  @relation(fields: [memberId], references: [id])

  @@map("users")
}

model Project {
  id          Int               @id @default(autoincrement())
  name        String
  client      String            @default("")
  location    String            @default("")
  discipline  String            @default("")
  quotedHours Float             @default(0) @map("quoted_hours")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  createdBy   String            @default("") @map("created_by")
  updatedBy   String            @default("") @map("updated_by")
  version     Int               @default(1)
  endDate     String            @default("") @map("end_date")
  startDate   String            @default("") @map("start_date")
  archived    Boolean           @default(false)
  allocations Allocation[]
  dispatches  Dispatch[]
  inputs      Input[]
  meetings    Meeting[]
  feedback    ProjectFeedback[]
  members     ProjectMember[]
  status      ProjectStatus?
  qcItems     QcItem[]
  queries     Query[]
  rfis        Rfi[]
  scopes      Scope[]
  standards   Standard[]
  tasks       Task[]
  timesheets  Timesheet[]
  wipTasks    WipTask[]

  @@map("projects")
}

model ProjectMember {
  id        Int     @id @default(autoincrement())
  projectId Int     @map("project_id")
  memberId  Int     @map("member_id")
  member    Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, memberId])
  @@index([projectId])
  @@map("project_members")
}

model ProjectStatus {
  id          Int      @id @default(autoincrement())
  projectId   Int      @unique @map("project_id")
  overall     String   @default("")
  notes       String   @default("")
  lastUpdated DateTime @default(now()) @map("last_updated")
  createdBy   String   @default("") @map("created_by")
  updatedBy   String   @default("") @map("updated_by")
  version     Int      @default(1)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_status")
}

model Rfi {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  data      Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @default("") @map("created_by")
  updatedBy String   @default("") @map("updated_by")
  version   Int      @default(1)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("rfis")
}

model Query {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  data      Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @default("") @map("created_by")
  updatedBy String   @default("") @map("updated_by")
  version   Int      @default(1)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("queries")
}

model Dispatch {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  data      Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @default("") @map("created_by")
  updatedBy String   @default("") @map("updated_by")
  version   Int      @default(1)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("dispatches")
}

