// Daily work allocation: a manager plans which task/project a member works on
// each day. data = { member_id, task_id?, date, hours?, note }.
model Allocation {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  data      Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @default("") @map("created_by")
  updatedBy String   @default("") @map("updated_by")
  version   Int      @default(1)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("allocations")
}

// Client registry — one record per client, reused across all their projects to
// avoid duplicating client info. `code` is a human-readable unique id (CL-0001).
model Client {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String   @unique
  company   String   @default("")
  contact   String   @default("") // legacy (no longer edited in the UI)
  email     String   @default("") // legacy
  phone     String   @default("") // legacy
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @default("") @map("created_by")
  updatedBy String   @default("") @map("updated_by")
  version   Int      @default(1)

  projects  Project[]

  @@map("clients")
}

// Standalone project quotation (created before a project exists, for prospects).
// Follows the company's fixed BIM scope-and-hours template; all template fields
// live in `data` JSON (quote_no, date, client_name, project_name, project_hours,
// qc_hours + detailed scope of work). Not linked to a Project on purpose.
model Quote {
  id        Int      @id @default(autoincrement())
  data      Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @default("") @map("created_by")
  updatedBy String   @default("") @map("updated_by")
  version   Int      @default(1)

  @@map("quotes")
}

// ── Attachments ───────────────────────────────────────────────────────────────
// entity_type matches the item `type` string (rfi, query, qc, standard, ...).
// Kept generic (no DB FK to a single table) since it points at many item types.

model Attachment {
  id          Int      @id @default(autoincrement())
  entityType  String   @map("entity_type")
  entityId    Int      @map("entity_id")
  filename    String
  storedPath  String   @map("stored_path")
  description String   @default("")
  response    String   @default("")
  importance  String   @default("Medium") // High | Medium | Low
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@map("attachments")
}

// ── App settings (single row) ─────────────────────────────────────────────────

model AppSetting {
  id   Int    @id @default(1)
  data Json   @default("{}") // smtp config etc.

  @@map("app_settings")
}
