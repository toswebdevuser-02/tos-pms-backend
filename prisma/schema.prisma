// Project Tracker — central PostgreSQL schema.
//
// Design: hybrid. Identity/relational data (members, users, projects,
// project_members, attachments, project_status) gets real typed columns + FKs
// so we get referential integrity and ON DELETE CASCADE. The variable
// per-type item content (RFI/Query/Dispatch/WIP/QC/Timesheet/Task/Standard/
// Scope/Meeting/Input) lives in a JSONB `data` column on one table per type —
// preserving the existing flexible row shapes and original ids, so the REST
// contract matches today's JSON store and attachments keep pointing at the
// same (entity_type, entity_id) pairs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
}

// ── Identity ────────────────────────────────────────────────────────────────

model Member {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @default("")
  role       String   @default("Employee") // Company Admin | Manager | Team Lead | Employee
  discipline String   @default("") // scopes Managers/Leads to a discipline
  engagement String   @default("") // "" = unset | Man-month | Miscellaneous
  skills     Json     @default("[]") // self-reported skill set [{skill,category,level,years}]
  status     String   @default("active") // active | left
  leftDate   String   @default("") @map("left_date")
  createdAt  DateTime @default(now()) @map("created_at")

  user             User?
  projectMembers   ProjectMember[]
  overtimeRequests OvertimeRequest[]

  @@map("members")
}

// Per-member, per-day overtime request. Approved hours extend that day's 8.5h
// task-allocation capacity; pending/rejected do not count.
model OvertimeRequest {
  id          Int      @id @default(autoincrement())
  memberId    Int      @map("member_id")
  date        String   // YYYY-MM-DD
  hours       Float    @default(0)
  status      String   @default("pending") // pending | approved | rejected
  reason      String   @default("")
  requestedAt DateTime @default(now()) @map("requested_at")
  decidedBy   String   @default("") @map("decided_by")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@map("overtime_requests")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("Member") // mirrors Member.role; server's source of truth for authz
  mustReset    Boolean  @default(true) @map("must_reset")
  createdAt    DateTime @default(now()) @map("created_at")

  memberId Int?    @unique @map("member_id")
  member   Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@map("users")
}

// ── Projects & assignment ─────────────────────────────────────────────────────

model Project {
  id          Int      @id @default(autoincrement())
  name        String
  client      String   @default("")
  location    String   @default("")
  discipline  String   @default("")
  type        String   @default("") // "" = standard | Man-month | Miscellaneous
  quotedHours Float    @default(0) @map("quoted_hours")
  startDate   String   @default("") @map("start_date")
  endDate     String   @default("") @map("end_date")
  archived    Boolean  @default(false)
  deletedAt   DateTime? @map("deleted_at") // soft-delete: in the recycle bin; purged 15 days later
  clientId    Int?     @map("client_id") // link to the Client registry (name kept denormalized in `client`)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdBy   String   @default("") @map("created_by")
  updatedBy   String   @default("") @map("updated_by")
  version     Int      @default(1)

  clientRef  Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  members    ProjectMember[]
  status     ProjectStatus?
  rfis       Rfi[]
  queries    Query[]
  dispatches Dispatch[]
  wipTasks   WipTask[]
  qcItems    QcItem[]
  timesheets Timesheet[]
  tasks      Task[]
  standards  Standard[]
  scopes     Scope[]
  meetings   Meeting[]
  inputs      Input[]
  feedback    ProjectFeedback[]
  allocations Allocation[]

  @@map("projects")
}

model ProjectMember {
  id        Int @id @default(autoincrement())
  projectId Int @map("project_id")
  memberId  Int @map("member_id")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  member  Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([projectId, memberId])
  @@index([projectId])
  @@map("project_members")
}

// Singleton per project (the app upserts one status row per project).
model ProjectStatus {
  id          Int      @id @default(autoincrement())
  projectId   Int      @unique @map("project_id")
  overall     String   @default("")
  notes       String   @default("")
  lastUpdated DateTime @default(now()) @map("last_updated")
  createdBy   String   @default("") @map("created_by")
  updatedBy   String   @default("") @map("updated_by")
  version     Int      @default(1)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_status")
}

// ── Item tables (hybrid: relational key columns + JSONB data) ─────────────────
// All share the same shape; one per type to preserve original id spaces.

model Rfi {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  data      Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @default("") @map("created_by")
  updatedBy String   @default("") @map("updated_by")
  version   Int      @default(1)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("rfis")
}

model Query {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  data      Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @default("") @map("created_by")
  updatedBy String   @default("") @map("updated_by")
  version   Int      @default(1)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("queries")
}

