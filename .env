# Secret used to sign JWT login tokens. Use a long random string.
JWT_SECRET="CHANGE_ME_to_a_long_random_string"

# How long a login stays valid.
JWT_EXPIRES_IN="12h"

# HTTP + WebSocket port the server listens on.
PORT=4000

# Where uploaded attachment files are stored on the server machine.
STORAGE_DIR="./storage/attachments"

# Path to an existing data.json to import (used by `npm run migrate:json`).
LEGACY_DATA_JSON="../../data.json"

REDIS_URL=redis://localhost:6379