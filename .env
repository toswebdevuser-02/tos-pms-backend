# Copy to .env and fill in. Keep .env out of version control.

# PostgreSQL connection. Create the DB first:  createdb project_tracker



# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL="postgresql://postgres.igyvjumkfrzotwoffjjp:tos-pms-tracker@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL="postgresql://postgres.igyvjumkfrzotwoffjjp:tos-pms-tracker@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require"


# # Connect to Postgres via the shared transaction-mode pooler (IPv4-only)




# Secret used to sign JWT login tokens. Use a long random string.
JWT_SECRET="CHANGE_ME_to_a_long_random_string"

# How long a login stays valid.
JWT_EXPIRES_IN="12h"

# HTTP + WebSocket port the server listens on.
PORT=4000

# Where uploaded attachment files are stored on the server machine.
STORAGE_DIR="./storage/attachments"

# Path to an existing data.json to import (used by `npm run migrate:json`).
LEGACY_DATA_JSON="../../data.json"
